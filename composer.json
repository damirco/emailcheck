{
    "name": "damirco/emailcheck",
    "description": "Validates email addresses",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Damirco\\Emailcheck\\": "src/"
        }
    },
    "autoload-dev": {
